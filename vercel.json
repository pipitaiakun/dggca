{
  "version": 2,
  "functions": {
    "server.js": {
      "runtime": "edge"
    }
  },
  "cleanUrls": true,
  "rewrites": [
    { "source": "/chat", "destination": "/server.js" },
    { "source": "/redeem", "destination": "/server.js" },
    { "source": "/config.js", "destination": "/server.js" },
    { "source": "/api/health", "destination": "/server.js" },
    { "source": "/", "destination": "/public/index.html" },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
