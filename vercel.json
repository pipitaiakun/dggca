{
  "version": 2,
  "functions": {
    "server.js": {
      "runtime": "edge"
    }
  },
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(chat|redeem|config.js|api/.*)",
      "destination": "/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
